{
  "manifest_version": 3,
  "name": "YMix — YouTube Crossfade Mixer",
  "version": "0.1.0",
  "description": "Плейлисты YouTube с плавным кроссфейдом между видео.",
  "action": {
    "default_title": "YMix",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://tmksdm.github.io;"
  }
}
